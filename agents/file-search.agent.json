{
  "purfle": "0.1",
  "id": "bbbbbbbb-bbbb-4bbb-bbbb-bbbbbbbbbbbb",
  "name": "Downloads File Search",
  "version": "1.0.0",
  "description": "Searches file contents in the user's Downloads folder using a grep-like tool. Returns matching lines with file path, line number, and surrounding context.",
  "identity": {
    "author": "Roman Noble",
    "email": "roman@purfle.dev",
    "key_id": "purfle-samples-key",
    "algorithm": "ES256",
    "issued_at": "2026-03-30T00:00:00Z",
    "expires_at": "2027-03-30T00:00:00Z",
    "signature": "eyJhbGciOiJFUzI1NiIsImtpZCI6InB1cmZsZS1zYW1wbGVzLWtleSJ9..QTqWm-pahYbrRmvwMAAd_wVkheB_-qlgryVyn_rg3IiRw614TOeIEr2ovI2wSzzF7qJ6pi1gWZKHyUEsgJkn_g"
  },
  "capabilities": [
    {
      "id": "filesystem",
      "required": false
    }
  ],
  "permissions": {
    "filesystem": {
      "read": [
        "C:/Users/*/Downloads/**/*.txt",
        "C:/Users/*/Downloads/**/*.md",
        "C:/Users/*/Downloads/**/*.cs",
        "C:/Users/*/Downloads/**/*.json",
        "C:/Users/*/Downloads/**/*.xml",
        "C:/Users/*/Downloads/**/*.yaml",
        "C:/Users/*/Downloads/**/*.yml",
        "C:/Users/*/Downloads/**/*.log",
        "C:/Users/*/Downloads/**/*.csv"
      ]
    },
    "environment": {
      "allow": [
        "GEMINI_API_KEY"
      ]
    }
  },
  "lifecycle": {
    "on_error": "terminate",
    "restartable": true
  },
  "runtime": {
    "requires": "purfle/0.1",
    "engine": "gemini",
    "model": "gemini-2.5-flash"
  },
  "io": {
    "input": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "The user's search request."
        }
      },
      "required": [
        "message"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "response": {
          "type": "string",
          "description": "Search results and summary."
        }
      },
      "required": [
        "response"
      ]
    }
  }
}
