{
  "purfle": "0.1",
  "id": "bbbbbbbb-bbbb-4bbb-bbbb-bbbbbbbbbbbb",
  "name": "Downloads File Search",
  "version": "1.0.0",
  "description": "Searches your Downloads folder. Supports .txt, .md, .cs, .json, .xml, .yaml, .yml, .log, and .csv files. Can find files by name/title or search inside file contents for keywords and phrases.",
  "identity": {
    "author": "Roman Noble",
    "email": "roman@purfle.dev",
    "key_id": "purfle-samples-key",
    "algorithm": "ES256",
    "issued_at": "2026-03-30T00:00:00Z",
    "expires_at": "2027-03-30T00:00:00Z",
    "signature": "placeholder-resigned-by-test"
  },
  "capabilities": ["llm.chat", "fs.read"],
  "permissions": {
    "fs.read": {
      "paths": [
        "C:/Users/*/Downloads/**/*.txt",
        "C:/Users/*/Downloads/**/*.md",
        "C:/Users/*/Downloads/**/*.cs",
        "C:/Users/*/Downloads/**/*.json",
        "C:/Users/*/Downloads/**/*.xml",
        "C:/Users/*/Downloads/**/*.yaml",
        "C:/Users/*/Downloads/**/*.yml",
        "C:/Users/*/Downloads/**/*.log",
        "C:/Users/*/Downloads/**/*.csv"
      ]
    }
  },
  "lifecycle": {
    "on_error": "terminate"
  },
  "runtime": {
    "requires": "purfle/0.1",
    "engine": "gemini",
    "model": "gemini-2.5-flash"
  }
}
