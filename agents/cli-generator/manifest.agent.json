{
  "$schema": "https://purfle.dev/schema/agent.manifest.schema.json",
  "purfle": "0.1",
  "agent": {
    "id": "dev.purfle.cli-generator",
    "name": "CLI Generator",
    "version": "1.0.0",
    "description": "Scaffolds CLI applications, adds commands with argument parsing, and generates help documentation across multiple frameworks"
  },
  "identity": {
    "type": "jws",
    "publicKey": {},
    "signature": ""
  },
  "capabilities": [
    { "id": "scaffold", "mcpTool": "mcp://localhost:8110/cli/scaffold" },
    { "id": "add-command", "mcpTool": "mcp://localhost:8110/cli/add-command" },
    { "id": "generate-help", "mcpTool": "mcp://localhost:8110/cli/generate-help" }
  ],
  "permissions": {
    "filesystem": { "write": ["./output"] },
    "network": { "required": ["generativelanguage.googleapis.com", "api.openai.com"] },
    "tools": { "mcp": ["mcp://localhost:8110/cli/*"] }
  },
  "runtime": {
    "inference": {
      "provider": "gemini",
      "model": "gemini-2.5-flash",
      "fallback": ["openai:gpt-4o"]
    },
    "entrypoints": {
      "dotnet": "csharp/bin/Release/net10.0/CliGenerator.dll",
      "node": "typescript/dist/index.js"
    },
    "resources": { "memory": "256MB", "timeout": 30000 }
  }
}
