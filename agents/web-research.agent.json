{
  "purfle": "0.1",
  "id": "cccccccc-cccc-4ccc-cccc-cccccccccccc",
  "name": "Purfle Web Research",
  "version": "1.0.0",
  "description": "Fetches web pages and synthesises research. Uses http_get for page content and extract_links to discover further URLs. Denies direct access to the Anthropic API.",
  "identity": {
    "author": "Roman Noble",
    "email": "roman@purfle.dev",
    "key_id": "purfle-samples-key",
    "algorithm": "ES256",
    "issued_at": "2026-03-30T00:00:00Z",
    "expires_at": "2027-03-30T00:00:00Z",
    "signature": "eyJhbGciOiJFUzI1NiIsImtpZCI6InB1cmZsZS1zYW1wbGVzLWtleSJ9..mPAj-FKeeXflc2RkZ76nWZVnpbc3ii2OdiZtuYa0k2-r2ZyFTwskmjHxAXy77TNd-0XU7dOSIek01CgdXpIn4Q"
  },
  "capabilities": [
    {
      "id": "web-search",
      "required": false
    }
  ],
  "permissions": {
    "network": {
      "allow": [
        "https://**"
      ],
      "deny": [
        "https://api.anthropic.com/**"
      ]
    },
    "environment": {
      "allow": [
        "GEMINI_API_KEY"
      ]
    }
  },
  "lifecycle": {
    "on_error": "terminate",
    "restartable": true
  },
  "runtime": {
    "requires": "purfle/0.1",
    "engine": "gemini",
    "model": "gemini-2.5-flash"
  },
  "io": {
    "input": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "The research question or topic."
        }
      },
      "required": [
        "message"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "response": {
          "type": "string",
          "description": "Research summary with source URLs."
        }
      },
      "required": [
        "response"
      ]
    }
  }
}
