<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Controls.AgentCard">
    <Border Padding="16" Margin="8,4"
            StrokeThickness="1"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
            StrokeShape="RoundRectangle 8">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">

            <!-- Name -->
            <Label Text="{Binding Name}"
                   FontAttributes="Bold"
                   FontSize="16" />

            <!-- Status row -->
            <HorizontalStackLayout Grid.Row="1" Spacing="8" VerticalOptions="Center">
                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         Color="{Binding StatusColor}"
                         VerticalOptions="Center" />
                <Label Text="{Binding StatusText}"
                       FontSize="13"
                       TextColor="Gray"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Run times -->
            <HorizontalStackLayout Grid.Row="2" Spacing="16">
                <Label FontSize="12" TextColor="Gray">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Last run: " FontAttributes="Bold"/>
                            <Span Text="{Binding LastRunText}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="12" TextColor="Gray">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Next run: " FontAttributes="Bold"/>
                            <Span Text="{Binding NextRunText}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <!-- View Log button -->
            <Button Text="View Log"
                    Grid.Row="3"
                    HorizontalOptions="Start"
                    BackgroundColor="Transparent"
                    TextColor="#5B5EA6"
                    FontSize="13"
                    Padding="0"
                    Command="{Binding ViewLogCommand}" />
        </Grid>
    </Border>
</ContentView>
