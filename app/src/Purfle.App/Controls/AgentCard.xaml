<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Controls.AgentCard">
    <Border Padding="16" Margin="8,4"
            StrokeThickness="1"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
            StrokeShape="RoundRectangle 8">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">

            <!-- Row 0: Name + Status indicator -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding Name}"
                       FontAttributes="Bold"
                       FontSize="16" />
                <!-- Status dot with color -->
                <Border Grid.Column="1"
                        WidthRequest="12" HeightRequest="12"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 6"
                        BackgroundColor="{Binding StatusColor}"
                        Opacity="{Binding StatusDotOpacity}"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Row 1: Status text -->
            <HorizontalStackLayout Grid.Row="1" Spacing="8" VerticalOptions="Center">
                <Label Text="{Binding StatusText}"
                       FontSize="13"
                       TextColor="{Binding StatusColor}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Row 2: Run times -->
            <HorizontalStackLayout Grid.Row="2" Spacing="16">
                <Label FontSize="12" TextColor="Gray">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Last run: " FontAttributes="Bold"/>
                            <Span Text="{Binding LastRunText}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="12" TextColor="Gray">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Next run: " FontAttributes="Bold"/>
                            <Span Text="{Binding NextRunText}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <!-- Row 3: Token usage -->
            <Label Grid.Row="3"
                   Text="{Binding TokenUsageText}"
                   FontSize="11"
                   TextColor="Gray"
                   IsVisible="{Binding HasTokenUsage}" />

            <!-- Row 4: Output preview -->
            <Frame Grid.Row="4"
                   Padding="8" Margin="0,4,0,0"
                   BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1A1A1A}"
                   BorderColor="{AppThemeBinding Light=#E8E8E8, Dark=#333}"
                   CornerRadius="4"
                   IsVisible="{Binding HasOutputPreview}">
                <Label Text="{Binding OutputPreview}"
                       FontSize="11"
                       FontFamily="Courier New"
                       TextColor="Gray"
                       LineBreakMode="TailTruncation"
                       MaxLines="2" />
            </Frame>

            <!-- Row 5: Error badge (tap to expand) -->
            <Frame Grid.Row="5"
                   Padding="8" Margin="0,4,0,0"
                   BackgroundColor="#FFF0F0"
                   BorderColor="#FFD0D0"
                   CornerRadius="4"
                   IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorText}"
                       FontSize="11"
                       TextColor="#CC0000"
                       LineBreakMode="TailTruncation"
                       MaxLines="{Binding ErrorMaxLines}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleErrorCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Frame>

            <!-- Row 6: Buttons -->
            <HorizontalStackLayout Grid.Row="6" Spacing="12">
                <Button Text="Run Now"
                        HorizontalOptions="Start"
                        BackgroundColor="Transparent"
                        TextColor="#4CAF50"
                        FontSize="13"
                        Padding="0"
                        Command="{Binding RunNowCommand}" />
                <Button Text="View Log"
                        HorizontalOptions="Start"
                        BackgroundColor="Transparent"
                        TextColor="#5B5EA6"
                        FontSize="13"
                        Padding="0"
                        Command="{Binding ViewLogCommand}" />
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>
