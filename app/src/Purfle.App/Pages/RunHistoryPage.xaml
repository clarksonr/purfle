<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.RunHistoryPage"
             Title="Run History">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16">

        <!-- Agent name header -->
        <Label x:Name="AgentNameLabel"
               FontSize="20" FontAttributes="Bold" />

        <!-- Filter bar -->
        <HorizontalStackLayout Grid.Row="1" Spacing="12" Margin="0,8,0,8">
            <Button x:Name="FilterAll" Text="All"
                    Clicked="OnFilterAll"
                    BackgroundColor="#5B5EA6" TextColor="White"
                    FontSize="12" Padding="12,4" HeightRequest="32" />
            <Button x:Name="FilterSuccess" Text="Success"
                    Clicked="OnFilterSuccess"
                    BackgroundColor="Transparent" TextColor="#4CAF50"
                    FontSize="12" Padding="12,4" HeightRequest="32" />
            <Button x:Name="FilterError" Text="Error"
                    Clicked="OnFilterError"
                    BackgroundColor="Transparent" TextColor="#CC0000"
                    FontSize="12" Padding="12,4" HeightRequest="32" />
            <Label x:Name="RunCountLabel" FontSize="12" TextColor="Gray"
                   VerticalOptions="Center" Margin="16,0,0,0" />
        </HorizontalStackLayout>

        <!-- Run list -->
        <CollectionView x:Name="RunList" Grid.Row="2">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="0,2"
                            StrokeThickness="1" Stroke="LightGray"
                            StrokeShape="RoundRectangle 6">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Padding="4">
                            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                     Color="{Binding StatusColor}" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                <Label Text="{Binding TimestampFormatted}"
                                       FontSize="13" FontAttributes="Bold" />
                                <Label Text="{Binding OutputPreview}"
                                       FontSize="11" TextColor="Gray"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding DurationText}"
                                   FontSize="11" TextColor="Gray" VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding StatusText}"
                                   FontSize="11" TextColor="{Binding StatusTextColor}"
                                   VerticalOptions="Center" Margin="8,0" />
                            <Button Grid.Column="4" Text="View"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnViewRun"
                                    FontSize="11" Padding="8,2"
                                    BackgroundColor="Transparent" TextColor="#5B5EA6" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Load more -->
        <Button x:Name="LoadMoreButton" Grid.Row="3"
                Text="Load more"
                Clicked="OnLoadMore"
                BackgroundColor="Transparent" TextColor="#5B5EA6"
                FontSize="13" IsVisible="False"
                HorizontalOptions="Center" Margin="0,8" />

    </Grid>

</ContentPage>
