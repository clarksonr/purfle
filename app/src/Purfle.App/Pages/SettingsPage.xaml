<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.SettingsPage"
             Title="Settings">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <!-- Stats section -->
            <Label Text="Agent Statistics"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label x:Name="StatsLabel"
                   Text="Loading..."
                   FontSize="13"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Marketplace URL"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Entry x:Name="RegistryUrlEntry"
                   Placeholder="http://localhost:5000"
                   Keyboard="Url" />
            <Button Text="Save"
                    Clicked="OnSaveUrl"
                    BackgroundColor="#1a1a2e"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Local Development"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="Install a .purfle bundle from a local file (bypasses marketplace)."
                   TextColor="Gray"
                   FontSize="13" />
            <Button Text="Install Bundle from File…"
                    Clicked="OnInstallBundle"
                    BackgroundColor="#5B5EA6"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Preferred Engine"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="Overrides the engine declared in each agent's manifest."
                   TextColor="Gray"
                   FontSize="13" />
            <Picker x:Name="EnginePicker">
                <Picker.Items>
                    <x:String>Use agent default</x:String>
                    <x:String>Anthropic</x:String>
                    <x:String>Google Gemini</x:String>
                </Picker.Items>
            </Picker>
            <Button Text="Save Engine Preference"
                    Clicked="OnSaveEngine"
                    BackgroundColor="#1a1a2e"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="API Keys"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="Anthropic"
                   TextColor="Gray"
                   FontSize="13" />
            <Entry x:Name="AnthropicKeyEntry"
                   Placeholder="sk-ant-..."
                   IsPassword="True" />
            <Label Text="Google Gemini"
                   TextColor="Gray"
                   FontSize="13" />
            <Entry x:Name="GeminiKeyEntry"
                   Placeholder="AIza..."
                   IsPassword="True" />
            <HorizontalStackLayout Spacing="8">
                <Button Text="Save API Keys"
                        Clicked="OnSaveApiKeys"
                        BackgroundColor="#1a1a2e"
                        TextColor="White" />
                <Button Text="Test Connection"
                        Clicked="OnTestConnection"
                        BackgroundColor="Transparent"
                        TextColor="#5B5EA6" />
            </HorizontalStackLayout>
            <Label x:Name="TestConnectionLabel"
                   Text=""
                   FontSize="12" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <!-- Clear output -->
            <Label Text="Data Management"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Button Text="Clear All Agent Output"
                    Clicked="OnClearOutput"
                    BackgroundColor="#CC0000"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Setup Wizard"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="Re-run the first-time setup wizard."
                   TextColor="Gray"
                   FontSize="13" />
            <Button Text="Reset Setup"
                    Clicked="OnResetSetup"
                    BackgroundColor="#CC0000"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Authentication"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label x:Name="AuthStatusLabel"
                   Text="Not authenticated."
                   TextColor="Gray" />
            <Button x:Name="LoginButton"
                    Text="Login"
                    Clicked="OnLogin"
                    BackgroundColor="#1a1a2e"
                    TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
