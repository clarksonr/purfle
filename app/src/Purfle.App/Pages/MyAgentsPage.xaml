<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Purfle.App.Controls"
             x:Class="Purfle.App.Pages.MyAgentsPage"
             Title="My Agents">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Install Agent"
                     Command="{Binding AddAgentCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Agents}" Spacing="0">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <controls:AgentCard BindingContext="{Binding}" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
