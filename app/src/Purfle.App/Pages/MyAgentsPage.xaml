<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Purfle.App.Controls"
             x:Class="Purfle.App.Pages.MyAgentsPage"
             Title="My Agents">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Install Agent"
                     Command="{Binding AddAgentCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <Grid RowDefinitions="Auto,*">

            <!-- Sort controls -->
            <HorizontalStackLayout Spacing="8" Margin="12,8"
                                   IsVisible="{Binding HasAgents}">
                <Label Text="Sort:" FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                <Button Text="Name"     FontSize="11" Padding="6,2"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        Command="{Binding SortCommand}" CommandParameter="name" />
                <Button Text="Last Run" FontSize="11" Padding="6,2"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        Command="{Binding SortCommand}" CommandParameter="lastrun" />
                <Button Text="Next Run" FontSize="11" Padding="6,2"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        Command="{Binding SortCommand}" CommandParameter="nextrun" />
                <Button Text="Status"   FontSize="11" Padding="6,2"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        Command="{Binding SortCommand}" CommandParameter="status" />
            </HorizontalStackLayout>

            <!-- Agent list -->
            <ScrollView Grid.Row="1" IsVisible="{Binding HasAgents}">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Agents}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <controls:AgentCard BindingContext="{Binding}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Empty state -->
            <VerticalStackLayout Grid.Row="1"
                                 IsVisible="{Binding IsEmpty}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="32">
                <Label Text="No Agents Installed"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="Install agents from the marketplace or add a manifest file to get started."
                       FontSize="14"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center" />
                <Button Text="Browse Marketplace"
                        BackgroundColor="#5B5EA6"
                        TextColor="White"
                        HorizontalOptions="Center"
                        Padding="24,12"
                        CornerRadius="8"
                        Clicked="OnBrowseMarketplace" />
                <Button Text="Install from File"
                        BackgroundColor="Transparent"
                        TextColor="#5B5EA6"
                        HorizontalOptions="Center"
                        Command="{Binding AddAgentCommand}" />
            </VerticalStackLayout>
        </Grid>
    </RefreshView>

</ContentPage>
