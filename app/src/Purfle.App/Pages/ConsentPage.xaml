<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.ConsentPage"
             Title="Agent Permissions">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <VerticalStackLayout>
                    <Label x:Name="AgentNameLabel"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="VersionLabel"
                               FontSize="13"
                               TextColor="Gray" />
                        <Label x:Name="AuthorLabel"
                               FontSize="13"
                               TextColor="Gray" />
                        <Border x:Name="VerifiedBadge"
                               BackgroundColor="#4CAF50"
                               Padding="4,2"
                               StrokeShape="RoundRectangle 4"
                               IsVisible="False">
                            <Label Text="Verified"
                                   TextColor="White"
                                   FontSize="11" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Signature status -->
                <Border x:Name="SignatureBadge"
                       Grid.Column="1"
                       Padding="8,4"
                       StrokeShape="RoundRectangle 6"
                       VerticalOptions="Center">
                    <Label x:Name="SignatureLabel"
                           FontSize="12" />
                </Border>
            </Grid>

            <Label x:Name="DescriptionLabel"
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- Schedule -->
            <Label Text="Schedule"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label x:Name="ScheduleLabel"
                   FontSize="13"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- Permissions -->
            <Label Text="This agent needs permission to:"
                   FontSize="14"
                   FontAttributes="Bold" />
            <VerticalStackLayout x:Name="PermissionsStack" Spacing="8" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- MCP Servers -->
            <Label x:Name="McpServersHeader"
                   Text="Required MCP Servers"
                   FontSize="14"
                   FontAttributes="Bold"
                   IsVisible="False" />
            <VerticalStackLayout x:Name="McpServersStack" Spacing="6" />

            <!-- Credentials -->
            <Label x:Name="CredentialsHeader"
                   Text="Required Credentials"
                   FontSize="14"
                   FontAttributes="Bold"
                   IsVisible="False" />
            <VerticalStackLayout x:Name="CredentialsStack" Spacing="6" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <!-- Actions -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button x:Name="AllowButton"
                        Text="Allow &amp; Install"
                        Clicked="OnAllow"
                        BackgroundColor="#4CAF50"
                        TextColor="White" />
                <Button Text="Cancel"
                        Clicked="OnCancel"
                        BackgroundColor="Transparent"
                        TextColor="#CC0000" />
            </HorizontalStackLayout>

            <!-- Raw manifest viewer -->
            <Label Text="View Raw Manifest"
                   TextColor="#5B5EA6"
                   FontSize="13"
                   TextDecorations="Underline"
                   Margin="0,8,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnToggleRawManifest" />
                </Label.GestureRecognizers>
            </Label>
            <Editor x:Name="RawManifestEditor"
                    IsReadOnly="True"
                    IsVisible="False"
                    FontFamily="Courier New"
                    FontSize="11"
                    HeightRequest="300"
                    BackgroundColor="#f5f5f5" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
