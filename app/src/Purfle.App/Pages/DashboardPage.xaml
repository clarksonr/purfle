<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.DashboardPage"
             Title="Dashboard">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <!-- Summary bar -->
            <Border Padding="16"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1E1E1E}">
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="{Binding TotalAgents}"
                               FontSize="28" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#5B5EA6" />
                        <Label Text="Installed"
                               FontSize="11" TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label Text="{Binding SuccessToday}"
                               FontSize="28" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#4CAF50" />
                        <Label Text="Success Today"
                               FontSize="11" TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label Text="{Binding ErrorCount}"
                               FontSize="28" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#CC0000" />
                        <Label Text="Errors"
                               FontSize="11" TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                        <Label Text="{Binding RunningCount}"
                               FontSize="28" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="Orange" />
                        <Label Text="Running"
                               FontSize="11" TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Today's Digest -->
            <Label Text="Today's Digest" FontSize="18" FontAttributes="Bold" />

            <!-- Digest content (from report-builder) -->
            <Border Padding="16"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A1A}"
                    IsVisible="{Binding HasDigest}">
                <Label Text="{Binding DigestText}"
                       FontSize="13"
                       FontFamily="Courier New"
                       LineBreakMode="WordWrap" />
            </Border>

            <!-- No digest placeholder -->
            <Border Padding="16"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
                    IsVisible="{Binding NoDigest}">
                <Label Text="report-builder hasn't run yet today."
                       FontSize="14" TextColor="Gray"
                       FontAttributes="Italic"
                       HorizontalTextAlignment="Center" />
            </Border>

            <!-- Agent Roster -->
            <Label Text="Agent Roster" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />

            <CollectionView ItemsSource="{Binding AgentRoster}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,2"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                                StrokeShape="RoundRectangle 6">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <!-- Status dot -->
                                <BoxView WidthRequest="10" HeightRequest="10"
                                         CornerRadius="5"
                                         Color="{Binding StatusColor}"
                                         VerticalOptions="Center" />

                                <!-- Name + last run -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="14" FontAttributes="Bold" />
                                    <Label Text="{Binding LastRun, StringFormat='Last run: {0}'}"
                                           FontSize="11" TextColor="Gray" />
                                </VerticalStackLayout>

                                <!-- Run Now button -->
                                <Button Grid.Column="2" Text="Run Now"
                                        Command="{Binding RunNowCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="#4CAF50"
                                        FontSize="12" Padding="8,4"
                                        VerticalOptions="Center" />

                                <!-- Navigate arrow -->
                                <Label Grid.Column="3" Text=">"
                                       FontSize="16" TextColor="Gray"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ViewDetailCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
