<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.RunDetailPage"
             Title="Run Detail">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">

            <!-- Run header -->
            <Label x:Name="RunAgentLabel" FontSize="18" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <BoxView x:Name="RunStatusDot" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                         VerticalOptions="Center" />
                <Label x:Name="RunStatusLabel" FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- Metadata grid -->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="16" RowSpacing="6">
                <Label Text="Started" FontSize="13" TextColor="Gray" />
                <Label x:Name="StartedLabel" Grid.Column="1" FontSize="13" />

                <Label Grid.Row="1" Text="Ended" FontSize="13" TextColor="Gray" />
                <Label x:Name="EndedLabel" Grid.Row="1" Grid.Column="1" FontSize="13" />

                <Label Grid.Row="2" Text="Duration" FontSize="13" TextColor="Gray" />
                <Label x:Name="DurationLabel" Grid.Row="2" Grid.Column="1" FontSize="13" />

                <Label Grid.Row="3" Text="Tokens" FontSize="13" TextColor="Gray" />
                <Label x:Name="TokensLabel" Grid.Row="3" Grid.Column="1" FontSize="13" />

                <Label Grid.Row="4" Text="Run ID" FontSize="13" TextColor="Gray" />
                <Label x:Name="RunIdLabel" Grid.Row="4" Grid.Column="1" FontSize="11"
                       FontFamily="Courier New" TextColor="Gray" />
            </Grid>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- Error section (visible only on error) -->
            <Border x:Name="ErrorSection" Padding="12"
                    StrokeThickness="2" Stroke="#CC0000"
                    StrokeShape="RoundRectangle 6"
                    BackgroundColor="#FFF0F0"
                    IsVisible="False">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Error" FontSize="14" FontAttributes="Bold" TextColor="#CC0000" />
                    <Label x:Name="ErrorLabel" FontSize="12" FontFamily="Courier New"
                           TextColor="#CC0000" />
                </VerticalStackLayout>
            </Border>

            <!-- Output content -->
            <Label Text="Output" FontSize="14" FontAttributes="Bold" />
            <Border Padding="12"
                    StrokeThickness="1" Stroke="LightGray"
                    StrokeShape="RoundRectangle 6"
                    BackgroundColor="#F8F8F8">
                <Editor x:Name="OutputEditor"
                        IsReadOnly="True"
                        FontFamily="Courier New"
                        FontSize="12"
                        HeightRequest="400"
                        BackgroundColor="Transparent" />
            </Border>

            <!-- Action buttons -->
            <HorizontalStackLayout Spacing="12" Margin="0,8">
                <Button x:Name="RetryButton" Text="Retry"
                        Clicked="OnRetry"
                        BackgroundColor="#5B5EA6" TextColor="White"
                        FontSize="13" Padding="16,6" />
                <Button Text="Open Output Folder"
                        Clicked="OnOpenFolder"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        FontSize="13" Padding="16,6" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
