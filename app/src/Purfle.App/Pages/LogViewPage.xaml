<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.LogViewPage"
             Title="Agent Log">
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Filter bar -->
        <HorizontalStackLayout Spacing="8" Margin="12,8">
            <Button Text="All"     x:Name="BtnAll"     Clicked="OnFilterAll"     FontSize="12" Padding="8,4" />
            <Button Text="Success" x:Name="BtnSuccess" Clicked="OnFilterSuccess" FontSize="12" Padding="8,4"
                    BackgroundColor="Transparent" TextColor="Green" />
            <Button Text="Error"   x:Name="BtnError"   Clicked="OnFilterError"   FontSize="12" Padding="8,4"
                    BackgroundColor="Transparent" TextColor="Red" />
            <Button Text="Refresh" Clicked="OnRefresh"  FontSize="12" Padding="8,4"
                    BackgroundColor="Transparent" TextColor="#5B5EA6"
                    HorizontalOptions="EndAndExpand" />
        </HorizontalStackLayout>

        <!-- Entry count -->
        <Label Grid.Row="1" x:Name="CountLabel"
               FontSize="11" TextColor="Gray" Margin="12,0" />

        <!-- Log entries -->
        <CollectionView Grid.Row="2" x:Name="LogEntries" Margin="4,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Margin="8,3"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                            StrokeShape="RoundRectangle 6">
                        <VerticalStackLayout Spacing="4">
                            <!-- Summary row -->
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <!-- Status dot -->
                                <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                         Color="{Binding StatusColor}"
                                         VerticalOptions="Center" />
                                <!-- Timestamp -->
                                <Label Grid.Column="1" Text="{Binding Timestamp}"
                                       FontSize="12" Margin="8,0,0,0"
                                       VerticalOptions="Center" />
                                <!-- Duration -->
                                <Label Grid.Column="2" Text="{Binding DurationText}"
                                       FontSize="11" TextColor="Gray"
                                       VerticalOptions="Center" Margin="0,0,8,0" />
                                <!-- Copy button -->
                                <Button Grid.Column="3" Text="Copy"
                                        FontSize="10" Padding="6,2"
                                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                                        Command="{Binding CopyCommand}" />
                            </Grid>

                            <!-- Token usage -->
                            <Label Text="{Binding TokenText}"
                                   FontSize="10" TextColor="Gray"
                                   IsVisible="{Binding HasTokens}" />

                            <!-- Detail (expanded) -->
                            <Frame Padding="8" Margin="0,4,0,0"
                                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}"
                                   BorderColor="Transparent" CornerRadius="4"
                                   IsVisible="{Binding IsExpanded}">
                                <Label Text="{Binding Detail}"
                                       FontSize="11" FontFamily="Courier New"
                                       TextColor="{AppThemeBinding Light=#333, Dark=#CCC}" />
                            </Frame>

                            <!-- Tap to expand -->
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
