<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Purfle.App.Pages.AgentDetailPage"
             Title="Agent Details">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Padding="16,16,16,8" Spacing="6">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout>
                    <Label x:Name="AgentName"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="VersionLabel" FontSize="13" TextColor="Gray" />
                        <Label x:Name="AuthorLabel" FontSize="13" TextColor="Gray" />
                        <Border x:Name="VerifiedBadge"
                                BackgroundColor="#4CAF50"
                                Padding="4,2"
                                StrokeShape="RoundRectangle 4"
                                Stroke="Transparent"
                                IsVisible="False">
                            <Label Text="Verified" TextColor="White" FontSize="10" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Status indicator -->
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <BoxView x:Name="StatusDot" WidthRequest="10" HeightRequest="10" CornerRadius="5"
                             Color="Gray" VerticalOptions="Center" />
                    <Label x:Name="StatusLabel" Text="Idle" FontSize="12" TextColor="Gray"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <Label x:Name="DescriptionLabel" FontSize="14" TextColor="Gray" />
            <Label x:Name="ScheduleLabel" FontSize="13" TextColor="Gray" />

            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                <Button x:Name="RunNowButton" Text="Run Now"
                        Clicked="OnRunNow"
                        BackgroundColor="#1a1a2e" TextColor="White"
                        HeightRequest="36" FontSize="13" Padding="12,0" />
                <Button x:Name="PauseButton" Text="Pause"
                        Clicked="OnPause"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        HeightRequest="36" FontSize="13" Padding="12,0" />
                <Button Text="Permissions"
                        Clicked="OnReviewPermissions"
                        BackgroundColor="Transparent" TextColor="#5B5EA6"
                        HeightRequest="36" FontSize="13" Padding="12,0" />
                <Button x:Name="UninstallButton" Text="Uninstall"
                        Clicked="OnUninstall"
                        BackgroundColor="Transparent" TextColor="#CC0000"
                        HeightRequest="36" FontSize="13" Padding="12,0" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,4" />

            <!-- Tab bar -->
            <HorizontalStackLayout Spacing="16">
                <Label x:Name="TabOverview" Text="Overview" FontSize="14" FontAttributes="Bold"
                       TextColor="#5B5EA6">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabOverview" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabPermissions" Text="Permissions" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabPermissions" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabFiles" Text="Files" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabFiles" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabHistory" Text="Run History" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabHistory" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabSystem" Text="System.md" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabSystem" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabUsage" Text="Usage" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabUsage" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="TabInstall" Text="Install" FontSize="14" TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabInstall" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Tab content -->
        <ScrollView Grid.Row="1" Padding="16,8">
            <Grid>

                <!-- Overview tab -->
                <VerticalStackLayout x:Name="OverviewPanel" Spacing="12" IsVisible="True">
                    <Label Text="Engine &amp; Model" FontSize="14" FontAttributes="Bold" />
                    <Label x:Name="EngineLabel" FontSize="13" TextColor="Gray" />

                    <Label Text="Token Usage" FontSize="14" FontAttributes="Bold" Margin="0,8,0,0" />
                    <Label x:Name="TokenLastRunLabel" FontSize="13" TextColor="Gray" />
                    <Label x:Name="TokenTodayLabel" FontSize="13" TextColor="Gray" />
                    <Label x:Name="TokenAllTimeLabel" FontSize="13" TextColor="Gray" />

                    <Label Text="Output Location" FontSize="14" FontAttributes="Bold" Margin="0,8,0,0" />
                    <Label x:Name="OutputPathLabel" FontSize="13" TextColor="#5B5EA6"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenOutputFolder" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Last / Next Run" FontSize="14" FontAttributes="Bold" Margin="0,8,0,0" />
                    <Label x:Name="LastRunLabel" FontSize="13" TextColor="Gray" />
                    <Label x:Name="NextRunLabel" FontSize="13" TextColor="Gray" />
                </VerticalStackLayout>

                <!-- Permissions tab -->
                <VerticalStackLayout x:Name="PermissionsPanel" Spacing="10" IsVisible="False">
                    <Label Text="Capabilities" FontSize="14" FontAttributes="Bold" />
                    <VerticalStackLayout x:Name="CapabilitiesStack" Spacing="6" />

                    <Label Text="MCP Servers" FontSize="14" FontAttributes="Bold" Margin="0,12,0,0" />
                    <VerticalStackLayout x:Name="McpStack" Spacing="6" />
                    <Button x:Name="RecheckMcpButton" Text="Re-check MCP Servers"
                            Clicked="OnRecheckMcp"
                            BackgroundColor="Transparent" TextColor="#5B5EA6"
                            FontSize="13" HorizontalOptions="Start" />
                </VerticalStackLayout>

                <!-- Files tab -->
                <VerticalStackLayout x:Name="FilesPanel" Spacing="10" IsVisible="False">
                    <Label Text="Read Paths" FontSize="14" FontAttributes="Bold" />
                    <VerticalStackLayout x:Name="ReadPathsStack" Spacing="4" />

                    <Label Text="Write Paths" FontSize="14" FontAttributes="Bold" Margin="0,12,0,0" />
                    <VerticalStackLayout x:Name="WritePathsStack" Spacing="4" />

                    <Label Text="Recent Output Files" FontSize="14" FontAttributes="Bold" Margin="0,12,0,0" />
                    <VerticalStackLayout x:Name="RecentFilesStack" Spacing="4" />
                </VerticalStackLayout>

                <!-- Run History tab -->
                <VerticalStackLayout x:Name="HistoryPanel" Spacing="10" IsVisible="False">
                    <Label x:Name="HistoryStatsLabel" FontSize="13" TextColor="Gray" />
                    <CollectionView x:Name="HistoryList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2"
                                        StrokeThickness="1"
                                        Stroke="LightGray"
                                        StrokeShape="RoundRectangle 4">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Padding="4">
                                        <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                                 Color="{Binding StatusColor}" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Timestamp}"
                                               FontSize="12" Margin="8,0" VerticalOptions="Center" />
                                        <Label Grid.Column="2" Text="{Binding DurationText}"
                                               FontSize="11" TextColor="Gray" VerticalOptions="Center" />
                                        <Label Grid.Column="3" Text="{Binding TokenText}"
                                               FontSize="11" TextColor="Gray" VerticalOptions="Center"
                                               Margin="8,0" />
                                        <Button Grid.Column="4" Text="View"
                                                Command="{Binding ViewCommand}"
                                                FontSize="10" Padding="6,2"
                                                BackgroundColor="Transparent" TextColor="#5B5EA6" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- System.md tab -->
                <VerticalStackLayout x:Name="SystemMdPanel" Spacing="8" IsVisible="False">
                    <Label Text="This is the instruction file that guides the agent's behavior."
                           FontSize="12" TextColor="Gray" />
                    <Editor x:Name="SystemMdEditor"
                            IsReadOnly="True"
                            FontFamily="Courier New"
                            FontSize="12"
                            HeightRequest="500"
                            BackgroundColor="#f5f5f5" />
                </VerticalStackLayout>

                <!-- Usage tab -->
                <VerticalStackLayout x:Name="UsagePanel" Spacing="10" IsVisible="False">
                    <Label Text="Token Usage" FontSize="14" FontAttributes="Bold" />
                    <Label x:Name="UsageSummaryLabel" FontSize="13" TextColor="Gray"
                           Text="Loading usage data..." />
                    <CollectionView x:Name="UsageList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="12" Padding="4,6">
                                    <Label Text="{Binding DateFormatted}" FontSize="11" />
                                    <Label Grid.Column="1" Text="{Binding Engine}" FontSize="11" TextColor="Gray" />
                                    <Label Grid.Column="2" Text="{Binding Model}" FontSize="11" TextColor="Gray" />
                                    <Label Grid.Column="3" Text="{Binding PromptTokensText}" FontSize="11" />
                                    <Label Grid.Column="4" Text="{Binding CompletionTokensText}" FontSize="11" />
                                    <Label Grid.Column="5" Text="{Binding TotalTokensText}" FontSize="11" FontAttributes="Bold" />
                                    <Label Grid.Column="6" Text="{Binding EstCost}" FontSize="11" TextColor="Gray" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Install tab -->
                <VerticalStackLayout x:Name="InstallPanel" Spacing="12" IsVisible="False">
                    <!-- Marketplace info -->
                    <Label x:Name="InstallAgentName" FontSize="16" FontAttributes="Bold" />
                    <Label x:Name="InstallVersion" FontSize="13" TextColor="Gray" />
                    <Label x:Name="InstallAuthor" FontSize="13" TextColor="Gray" />
                    <Label x:Name="InstallDescription" FontSize="13" />
                    <Label x:Name="InstallHash" FontSize="11" FontFamily="Courier New" TextColor="Gray" />

                    <!-- Offline message -->
                    <Border x:Name="InstallOfflineBorder" Padding="12"
                            StrokeThickness="1" Stroke="Orange"
                            StrokeShape="RoundRectangle 6"
                            BackgroundColor="#FFF8E1"
                            IsVisible="False">
                        <Label x:Name="InstallOfflineLabel"
                               Text="Marketplace API is unreachable. Check your network connection."
                               FontSize="13" TextColor="#E65100" />
                    </Border>

                    <!-- Install button -->
                    <Button x:Name="InstallButton" Text="Install"
                            Clicked="OnInstallClicked"
                            BackgroundColor="#5B5EA6" TextColor="White"
                            HeightRequest="40" FontSize="14" Padding="24,0"
                            HorizontalOptions="Start" />

                    <!-- Progress indicator -->
                    <ActivityIndicator x:Name="InstallProgress"
                                       IsRunning="False" IsVisible="False"
                                       HorizontalOptions="Start" />

                    <!-- Live CLI output -->
                    <Border x:Name="InstallLogBorder" Padding="8"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1A1A1A}"
                            IsVisible="False">
                        <Editor x:Name="InstallLogEditor"
                                IsReadOnly="True"
                                FontFamily="Courier New"
                                FontSize="11"
                                HeightRequest="200"
                                BackgroundColor="Transparent" />
                    </Border>

                    <!-- Success banner -->
                    <Border x:Name="InstallSuccessBanner" Padding="12"
                            StrokeThickness="1" Stroke="#4CAF50"
                            StrokeShape="RoundRectangle 6"
                            BackgroundColor="#E8F5E9"
                            IsVisible="False">
                        <Label Text="Installed successfully!"
                               FontSize="14" TextColor="#2E7D32" FontAttributes="Bold" />
                    </Border>

                    <!-- Error box with retry -->
                    <Border x:Name="InstallErrorBorder" Padding="12"
                            StrokeThickness="2" Stroke="#CC0000"
                            StrokeShape="RoundRectangle 6"
                            BackgroundColor="#FFF0F0"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="InstallErrorLabel"
                                   FontSize="12" TextColor="#CC0000"
                                   FontFamily="Courier New" />
                            <Button Text="Retry"
                                    Clicked="OnInstallClicked"
                                    BackgroundColor="#CC0000" TextColor="White"
                                    FontSize="12" Padding="16,4"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
