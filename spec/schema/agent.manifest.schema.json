{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purfle.dev/schema/0.1/agent.manifest.schema.json",
  "title": "Purfle Agent Manifest",
  "description": "Defines the identity, capabilities, permissions, and runtime configuration of a Purfle agent package.",
  "type": "object",
  "required": ["purfle", "id", "name", "version", "identity", "capabilities", "runtime"],
  "additionalProperties": false,
  "properties": {
    "purfle": {
      "type": "string",
      "description": "Spec version the manifest targets.",
      "pattern": "^\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "description": "UUID v4 — globally unique agent identifier.",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable agent name.",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this agent.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "description": "What the agent does.",
      "maxLength": 1024
    },
    "identity": {
      "$ref": "#/$defs/identityBlock"
    },
    "capabilities": {
      "type": "array",
      "description": "Runtime capabilities this agent requires. Each string must be a phase-1 capability identifier.",
      "items": { "$ref": "#/$defs/capabilityString" },
      "minItems": 0,
      "uniqueItems": true
    },
    "permissions": {
      "$ref": "#/$defs/permissionsMap"
    },
    "schedule": {
      "$ref": "#/$defs/scheduleBlock"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycleBlock"
    },
    "runtime": {
      "$ref": "#/$defs/runtimeBlock"
    },
    "tools": {
      "type": "array",
      "description": "MCP tool bindings the AIVM wires at load time.",
      "items": { "$ref": "#/$defs/toolBinding" }
    },
    "io": {
      "type": "object",
      "description": "Optional input/output schema hints. No enforcement in phase 1."
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["llm.chat"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "llm.chat" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["llm.completion"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "llm.completion" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["network.outbound"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "network.outbound" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["env.read"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "env.read" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["fs.read"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "fs.read" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["fs.write"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "fs.write" } } }
      }
    },
    {
      "if": {
        "required": ["permissions"],
        "properties": { "permissions": { "type": "object", "required": ["mcp.tool"] } }
      },
      "then": {
        "properties": { "capabilities": { "type": "array", "contains": { "const": "mcp.tool" } } }
      }
    }
  ],
  "$defs": {
    "capabilityString": {
      "type": "string",
      "description": "Phase-1 capability identifiers.",
      "enum": [
        "llm.chat",
        "llm.completion",
        "network.outbound",
        "env.read",
        "fs.read",
        "fs.write",
        "mcp.tool"
      ]
    },
    "scheduleBlock": {
      "type": "object",
      "description": "Defines when and how often the AIVM triggers this agent.",
      "required": ["trigger"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "string",
          "description": "Trigger type: interval (every N minutes), cron (cron expression), startup (once on AIVM start).",
          "enum": ["interval", "cron", "startup"]
        },
        "interval_minutes": {
          "type": "integer",
          "description": "Required when trigger is 'interval'. How often to run in minutes.",
          "minimum": 1
        },
        "cron": {
          "type": "string",
          "description": "Required when trigger is 'cron'. Standard 5-field cron expression.",
          "minLength": 1
        }
      },
      "if": { "properties": { "trigger": { "const": "interval" } } },
      "then": { "required": ["interval_minutes"] },
      "else": {
        "if": { "properties": { "trigger": { "const": "cron" } } },
        "then": { "required": ["cron"] }
      }
    },
    "identityBlock": {
      "type": "object",
      "description": "Cryptographic identity block. signature is omitted at authoring time and added by the SDK on publish.",
      "required": ["author", "email", "key_id", "algorithm", "issued_at", "expires_at"],
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": "string",
          "description": "Reverse-domain publisher identifier or username.",
          "minLength": 1,
          "maxLength": 256
        },
        "email": {
          "type": "string",
          "description": "Contact email of the author.",
          "format": "email"
        },
        "key_id": {
          "type": "string",
          "description": "Identifier of the signing key registered in the Purfle key registry.",
          "minLength": 1
        },
        "algorithm": {
          "const": "ES256",
          "description": "JWA algorithm. ES256 is the only supported value in v0.1."
        },
        "issued_at": {
          "type": "string",
          "description": "ISO 8601 timestamp when the manifest was signed.",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "description": "ISO 8601 timestamp after which the manifest is invalid.",
          "format": "date-time"
        },
        "signature": {
          "type": "string",
          "description": "JWS Compact Serialization of the signed canonical manifest body. Omit at authoring time.",
          "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]*\\.[A-Za-z0-9_-]+$"
        }
      }
    },
    "runtimeBlock": {
      "type": "object",
      "description": "Inference engine and model configuration.",
      "required": ["requires", "engine"],
      "additionalProperties": false,
      "properties": {
        "requires": {
          "type": "string",
          "description": "Minimum Purfle runtime version required.",
          "pattern": "^purfle/\\d+\\.\\d+$"
        },
        "engine": {
          "type": "string",
          "description": "Inference adapter to use.",
          "enum": ["anthropic", "openclaw", "ollama"]
        },
        "model": {
          "type": "string",
          "description": "Model identifier passed to the engine adapter."
        },
        "max_tokens": {
          "type": "integer",
          "description": "Maximum tokens the model may generate per turn.",
          "minimum": 1
        }
      }
    },
    "lifecycleBlock": {
      "type": "object",
      "description": "AIVM lifecycle hooks and error policy.",
      "required": ["on_error"],
      "additionalProperties": false,
      "properties": {
        "on_load": {
          "type": "string",
          "description": ".NET assembly-qualified type name invoked after the agent is loaded."
        },
        "on_unload": {
          "type": "string",
          "description": ".NET assembly-qualified type name invoked before the agent is unloaded."
        },
        "on_error": {
          "type": "string",
          "description": "AIVM behavior when the agent throws an unhandled error.",
          "enum": ["terminate", "log", "ignore"]
        }
      }
    },
    "toolBinding": {
      "type": "object",
      "description": "A single MCP tool binding wired by the AIVM at load time.",
      "required": ["name", "server"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name as exposed to the LLM.",
          "minLength": 1
        },
        "server": {
          "type": "string",
          "description": "MCP server URL the AIVM connects to for this tool."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description forwarded to the LLM tool schema."
        }
      }
    },
    "permissionConfig": {
      "description": "Configuration block for a single capability's permission grant.",
      "oneOf": [
        { "$ref": "#/$defs/networkOutboundConfig" },
        { "$ref": "#/$defs/envReadConfig" },
        { "$ref": "#/$defs/fsConfig" },
        { "$ref": "#/$defs/emptyPermConfig" }
      ]
    },
    "networkOutboundConfig": {
      "type": "object",
      "description": "Permission config for network.outbound — lists allowed hostnames.",
      "required": ["hosts"],
      "additionalProperties": false,
      "properties": {
        "hosts": {
          "type": "array",
          "description": "Hostnames the agent may connect to.",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "envReadConfig": {
      "type": "object",
      "description": "Permission config for env.read — lists readable environment variable names.",
      "required": ["vars"],
      "additionalProperties": false,
      "properties": {
        "vars": {
          "type": "array",
          "description": "Environment variable names the agent may read.",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "fsConfig": {
      "type": "object",
      "description": "Permission config for fs.read or fs.write — lists allowed paths.",
      "required": ["paths"],
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "description": "Filesystem paths the agent may access.",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "emptyPermConfig": {
      "type": "object",
      "description": "Permission config for capabilities that require no configuration (llm.chat, llm.completion, mcp.tool).",
      "additionalProperties": false
    },
    "permissionsMap": {
      "type": "object",
      "description": "Permission grants keyed by capability string. Every key must appear in capabilities[].",
      "additionalProperties": false,
      "properties": {
        "llm.chat":        { "$ref": "#/$defs/emptyPermConfig" },
        "llm.completion":  { "$ref": "#/$defs/emptyPermConfig" },
        "network.outbound":{ "$ref": "#/$defs/networkOutboundConfig" },
        "env.read":        { "$ref": "#/$defs/envReadConfig" },
        "fs.read":         { "$ref": "#/$defs/fsConfig" },
        "fs.write":        { "$ref": "#/$defs/fsConfig" },
        "mcp.tool":        { "$ref": "#/$defs/emptyPermConfig" }
      }
    }
  }
}
