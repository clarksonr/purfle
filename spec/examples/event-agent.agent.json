{
  "purfle": "0.1",
  "id": "f6c8d0e2-5678-4ef0-d123-555555555555",
  "name": "Webhook Responder",
  "version": "1.0.0",
  "description": "Runs immediately when a webhook event is received from the configured MCP server.",
  "identity": {
    "author": "clarksonr",
    "email": "roman@example.com",
    "key_id": "com.clarksonr/release-2026",
    "algorithm": "ES256",
    "issued_at": "2026-04-01T00:00:00Z",
    "expires_at": "2027-04-01T00:00:00Z"
  },
  "capabilities": ["llm.chat", "network.outbound", "fs.write"],
  "permissions": {
    "network.outbound": {
      "hosts": ["localhost:9090"]
    },
    "fs.write": {
      "paths": ["./output"]
    }
  },
  "schedule": {
    "trigger": "event",
    "event": {
      "source": "http://localhost:9090",
      "topic": "webhook.received"
    }
  },
  "runtime": {
    "requires": "purfle/0.1",
    "engine": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "max_tokens": 1024
  },
  "lifecycle": {
    "on_error": "log"
  }
}
