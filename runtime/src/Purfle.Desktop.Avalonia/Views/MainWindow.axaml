<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Purfle.Desktop.Avalonia.ViewModels"
        x:Class="Purfle.Desktop.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Purfle AIVM"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="#1E1E2E" Padding="16">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Purfle" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center" />
          <TextBlock Text="AIVM" FontSize="14" Foreground="#A6ADC8" VerticalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>
        <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}" Margin="8,0" />
        <Button Grid.Column="2" Content="Sort by Name" Command="{Binding SortCommand}" CommandParameter="name" />
      </Grid>
    </Border>

    <!-- Agent list or empty state -->
    <Panel Grid.Row="1" Background="#181825">

      <!-- Empty state -->
      <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="No agents installed" FontSize="18" Foreground="#A6ADC8" HorizontalAlignment="Center" />
        <TextBlock Text="Install agents to ~/.purfle/agents/ and restart" FontSize="13" Foreground="#585B70" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Agent cards -->
      <ScrollViewer IsVisible="{Binding HasAgents}" Padding="16">
        <ItemsControl ItemsSource="{Binding Agents}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AgentCardViewModel">
              <Border Background="#313244" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                  <!-- Name + Status -->
                  <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding StatusColor}" />
                      </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#CDD6F4" />
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>

                  <!-- Run Now button -->
                  <Button Grid.Row="0" Grid.Column="1" Content="Run Now" Click="OnRunNowClick" Tag="{Binding}" Padding="12,4" />

                  <!-- Timing -->
                  <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" Margin="18,6,0,0">
                    <TextBlock FontSize="12" Foreground="#585B70">
                      <Run Text="Last: " /><Run Text="{Binding LastRunText}" />
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#585B70">
                      <Run Text="Next: " /><Run Text="{Binding NextRunText}" />
                    </TextBlock>
                  </StackPanel>

                  <!-- Output preview -->
                  <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding OutputPreview}"
                             IsVisible="{Binding HasOutputPreview}"
                             FontSize="12" Foreground="#A6ADC8" Margin="18,6,0,0"
                             TextTrimming="CharacterEllipsis" MaxLines="2" />

                  <!-- Error -->
                  <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ErrorText}"
                             IsVisible="{Binding HasError}"
                             FontSize="12" Foreground="#F38BA8" Margin="18,6,0,0"
                             MaxLines="3" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Panel>

  </Grid>
</Window>
