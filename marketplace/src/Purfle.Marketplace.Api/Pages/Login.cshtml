@page "/login"
@model Purfle.Marketplace.Api.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In — Purfle Marketplace";
}
<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); width: 360px; }
        h1 { font-size: 1.5rem; margin: 0 0 1.5rem; text-align: center; }
        label { display: block; margin-bottom: 0.25rem; font-weight: 500; font-size: 0.9rem; }
        input[type=email], input[type=password] { width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; margin-bottom: 1rem; }
        button { width: 100%; padding: 0.6rem; background: #1a1a2e; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem; }
        button:hover { background: #16213e; }
        .error { color: #dc3545; font-size: 0.85rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Purfle Marketplace</h1>
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="error">@Model.Error</div>
        }
        <form method="post">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autofocus />
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />
            <button type="submit">Sign In</button>
        </form>
    </div>
</body>
</html>
